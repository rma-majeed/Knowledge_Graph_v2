# Automotive Consulting GraphRAG — Provider Configuration
# Copy this file to .env and fill in your values.
# When .env is absent, the system defaults to LM Studio at localhost:1234.

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Supported providers: lm-studio (default), ollama, gemini, openai, anthropic

# --- LM Studio (default — no API key required) ---
# LLM_PROVIDER=lm-studio
# LLM_MODEL=Qwen2.5-7B-Instruct
# LLM_API_BASE=http://localhost:1234    # optional: override default port

# --- Ollama (local — no API key required) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2
# LLM_API_BASE=http://localhost:11434   # optional: override default port

# --- Google Gemini ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.5-flash
# LLM_API_KEY=your-gemini-api-key-here

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-api-key-here

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Embedding Provider Configuration
# =============================================================================
# Supported providers: lm-studio (default), ollama, gemini, openai
# Note: Anthropic does NOT support embeddings.
# WARNING: Changing EMBED_MODEL after embedding requires full re-embedding.

# --- LM Studio (default — no API key required) ---
# EMBED_PROVIDER=lm-studio
# EMBED_MODEL=nomic-embed-text-v1.5
# EMBED_API_BASE=http://localhost:1234  # optional: override default port

# --- Ollama (local — no API key required) ---
# EMBED_PROVIDER=ollama
# EMBED_MODEL=nomic-embed-text

# --- Google Gemini ---
# EMBED_PROVIDER=gemini
# EMBED_MODEL=gemini/text-embedding-004
# EMBED_API_KEY=your-gemini-api-key-here

# --- OpenAI ---
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# LM Studio / LiteLLM (Google ADK routing)
# =============================================================================
# Required when using LM Studio as the ADK agent backend via LiteLLM.
# OPENAI_API_BASE=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=lm-studio

# =============================================================================
# RAG Feature Flags
# =============================================================================
# RAG_ENABLE_RERANKER=false      # BGE cross-encoder reranker (requires model download — see download_reranker_clean.py)
# RAG_ENABLE_PARENT_DOC=false    # Expand retrieved chunks to parent passages at query time
# RAG_ENABLE_ENRICHMENT=false    # LLM-enriched chunk summaries at ingest time (re-ingest required)

# =============================================================================
# HuggingFace Token (for downloading BGE reranker model)
# =============================================================================
# Get a free token at huggingface.co → Settings → Access Tokens (Read scope)
# HF_TOKEN=hf_your_token_here
