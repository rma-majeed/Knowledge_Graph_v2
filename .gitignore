# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Runtime data (generated by pipeline — not committed) ──────────────────────
data/chunks.db
data/extraction_state.json

# ChromaDB vector store (folder tracked via .gitkeep, data ignored)
data/chroma_db/*
!data/chroma_db/.gitkeep

# KuzuDB knowledge graph (folder tracked via .gitkeep, data ignored)
data/kuzu_db/*
!data/kuzu_db/.gitkeep

# ── Claude Code internal tooling ──────────────────────────────────────────────
.claude/

# ── OS / editor artefacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
